{
  "name": "meetwise-local",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Google Meet caption capture, speaker analytics, and Ollama meeting summaries",
  "author": "Meetwise Local contributors",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/pycarrot/meetwise-local.git"
  },
  "bugs": {
    "url": "https://github.com/pycarrot/meetwise-local/issues"
  },
  "homepage": "https://github.com/pycarrot/meetwise-local#readme",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:server": "node --watch server/index.mjs",
    "build": "tsc -b && vite build",
    "start": "node server/index.mjs",
    "test": "node --test server/*.test.mjs",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:extension": "node scripts/package-extension.mjs",
    "check": "npm run format:check && npm run lint && npm run test && npm run build && npm run package:extension",
    "qa:visual": "node scripts/visual-qa.mjs"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "archiver": "^7.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright-core": "^1.55.0",
    "prettier": "^3.6.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
