# Required for production/server mode
NODE_ENV=production
DEPLOYMENT_MODE=server
HOST=0.0.0.0
PORT=4317
PUBLIC_BASE_URL=https://meetwise.example.com
DATABASE_URL=file:/app/data/meetwise.db
SESSION_SECRET=
TOKEN_SIGNING_SECRET=
CORS_ALLOWED_ORIGINS=chrome-extension://replace-with-your-built-extension-id

# SQLite locking (WAL mode is enabled automatically)
DATABASE_BUSY_TIMEOUT_MS=15000

# Ollama (server-side only)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=120000
OLLAMA_HEALTH_TIMEOUT_MS=2500
OLLAMA_MAX_CONCURRENCY=1
OLLAMA_MAX_TRANSCRIPT_CHARS=300000
ANALYSIS_MAX_ATTEMPTS=3
ANALYSIS_JOB_LOCK_TIMEOUT_MS=300000

# Reverse proxy and operations
TRUST_PROXY=1
LOG_LEVEL=info
MAX_JSON_BODY=5mb
SESSION_TTL_HOURS=168
EXTENSION_ACCESS_TTL_MINUTES=10
EXTENSION_REFRESH_TTL_DAYS=30

# Compose-only values (keep outside version control)
PUBLIC_HOST=meetwise.example.com

# Extension release build (must be HTTPS)
EXTENSION_SERVER_URL=https://meetwise.example.com
EXTENSION_BUILD_MODE=production

# Development only example overrides
# NODE_ENV=development
# DEPLOYMENT_MODE=local
# HOST=127.0.0.1
# PUBLIC_BASE_URL=http://127.0.0.1:4317
# DATABASE_URL=file:./data/meetwise.db
# OLLAMA_URL=http://127.0.0.1:11434
# TRUST_PROXY=false
