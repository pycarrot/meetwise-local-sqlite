{
  "manifest_version": 3,
  "name": "Meetwise Capturer",
  "version": "__VERSION__",
  "description": "จับคำบรรยาย Google Meet และส่งไปยัง Meetwise server ที่คุณกำหนด",
  "permissions": ["activeTab", "alarms", "storage"],
  "host_permissions": ["https://meet.google.com/*", "__SERVER_ORIGIN__/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_icon": { "16": "assets/icons/icon16.png", "32": "assets/icons/icon32.png" },
    "default_popup": "popup.html",
    "default_title": "Meetwise Capturer"
  }
}
